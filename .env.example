# -----------------------------------------------------------------------------
# ISOCDELABS OPS HUB - ENVIRONMENT TEMPLATE
# Copy this file to '.env' and fill in the actual keys/credentials.
# -----------------------------------------------------------------------------

# --- Database & Authentication ---
# PostgreSQL connection URL (e.g. WSL PostgreSQL instance auto-forwarded to Windows localhost)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/isocodelabs_ops_hub?schema=public&connect_timeout=30&pool_timeout=30"

# JWT secret key used to sign session tokens (Required, do not expose or share)
JWT_SECRET="generate-a-secure-random-secret-key-phrase-here"

# --- Google OAuth Integrations ---
# Google Console Client ID and Secret for Calendar (Meetings) and Gmail API sync
GOOGLE_CLIENT_ID="your-google-oauth-client-id-here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret-here"

# Authorized redirect URI configured in Google API console (matches the oauth callback route)
GOOGLE_REDIRECT_URI="http://localhost:3003/api/auth/google/callback"

# --- Google Cloud Platform (Vertex AI) ---
# GCP project ID and region location (used for Google Vertex AI SDK / Gemini Pro models)
GCP_PROJECT_ID="your-gcp-project-id"
GCP_LOCATION="us-central1"

# --- WhatsApp Business Cloud API ---
# Access Token and Phone Number ID from Meta Developer Console.
# Use 'mock-whatsapp-token' to bypass real API calls during local testing.
WHATSAPP_API_TOKEN="mock-whatsapp-token"
WHATSAPP_PHONE_NUMBER_ID="mock-phone-number-id"

# --- Google AI Studio (Gemini/Imagen/Veo API) ---
# Unified API Key for Google AI Studio services (Imagen 3.0 image, Veo 2.0 video generation).
# Use 'mock-google-ai-key' to run local simulated image and video mock generations.
GOOGLE_AI_API_KEY="mock-google-ai-key"

# --- Realtime WebSocket & Caching ---
# Redis instance URL for server pub/sub event handling
REDIS_URL="redis://localhost:6379"

# Public WebSocket URL endpoint (connects client socket.io to the running next dev/prod server)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3003"
